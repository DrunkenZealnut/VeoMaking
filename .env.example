# Google Gemini API Key
# https://aistudio.google.com/app/apikey 에서 발급받을 수 있습니다.

# 단일 키 사용
GEMINI_API_KEY=your-api-key-here

# 여러 키 사용 (쉼표로 구분, 할당량 초과 시 자동 전환)
# GEMINI_API_KEYS=key1,key2,key3

# 접속 비밀번호 (필수 — 설정하지 않으면 로그인 시 500 에러 발생)
ACCESS_PASSWORD=your-password-here

# Supabase 로깅 (선택사항 — 없으면 로그인 기록이 저장되지 않음)
# https://supabase.com 에서 프로젝트 생성 후 발급
SUPABASE_URL=
SUPABASE_KEY=
